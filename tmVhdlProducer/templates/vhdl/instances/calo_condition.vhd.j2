{%- block instantiate_calo_condition %}
  {%- set o1 = condition.objects[0] %}
  {%- set o2 = condition.objects[1] %}
  {%- set o3 = condition.objects[2] %}
  {%- set o4 = condition.objects[3] %}
  
{{ condition.vhdl_signal }}_i: entity work.calo_conditions
    generic map(
        obj_type => {{ o1.type|upper }}_TYPE,
        nr_obj => NR_{{ o1.type|upper }}_OBJECTS,
        muon_object_slice_1_low => {{ o1.sliceLow }}, muon_object_slice_1_high => {{ o1.sliceHigh }}, 
    {%- if condition.nr_objects >= 2 %}
        muon_object_slice_2_low => {{ o2.sliceLow }}, muon_object_slice_2_high => {{ o2.sliceHigh }}, 
    {%- endif %}    
    {%- if condition.nr_objects >= 3 %}
        muon_object_slice_3_low => {{ o3.sliceLow }}, muon_object_slice_3_high => {{ o3.sliceHigh }}, 
    {%- endif %}    
    {%- if condition.nr_objects >= 4 %}
        muon_object_slice_4_low => {{ o4.sliceLow }}, muon_object_slice_4_high => {{ o4.sliceHigh }}, 
    {%- endif %}    
        nr_templates => {{ condition.nr_objects }},
    {%- if o1.operator == 'false'  %}
        pt_ge_mode => {{ o1.operator }},
    {%- endif %}
        pt_thresholds => (X"{{ o1.threshold|X04 }}", X"{{ o2.threshold|X04 }}", X"{{ o3.threshold|X04 }}", X"{{ o4.threshold|X04 }}"),
    {%- if o1.etaNrCuts == 0  %}
        -- no eta cuts
    {%- endif %}
    {%- if o1.etaNrCuts >= 1 or o2.etaNrCuts >= 1 or o3.etaNrCuts >= 1 or o4.etaNrCuts >= 1 %}
        nr_eta_windows => {{ o1.etaNrCuts }},
        eta_w1_upper_limits => (X"{{ o1.etaW1UpperLimit|X04 }}", X"{{ o2.etaW1UpperLimit|X04 }}", X"{{ o3.etaW1UpperLimit|X04 }}", X"{{ o4.etaW1UpperLimit|X04 }}"), 
        eta_w1_lower_limits => (X"{{ o1.etaW1LowerLimit|X04 }}", X"{{ o2.etaW1LowerLimit|X04 }}", X"{{ o3.etaW1LowerLimit|X04 }}", X"{{ o4.etaW1LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 2 or o2.etaNrCuts >= 2 or o3.etaNrCuts >= 2 or o4.etaNrCuts >= 2 %}
        eta_w2_upper_limits => (X"{{ o1.etaW2UpperLimit|X04 }}", X"{{ o2.etaW2UpperLimit|X04 }}", X"{{ o3.etaW2UpperLimit|X04 }}", X"{{ o4.etaW2UpperLimit|X04 }}"), 
        eta_w2_lower_limits => (X"{{ o1.etaW2LowerLimit|X04 }}", X"{{ o2.etaW2LowerLimit|X04 }}", X"{{ o3.etaW2LowerLimit|X04 }}", X"{{ o4.etaW2LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 3 or o2.etaNrCuts >= 3 or o3.etaNrCuts >= 3 or o4.etaNrCuts >= 3 %}
        eta_w3_upper_limits => (X"{{ o1.etaW3UpperLimit|X04 }}", X"{{ o2.etaW3UpperLimit|X04 }}", X"{{ o3.etaW3UpperLimit|X04 }}", X"{{ o4.etaW3UpperLimit|X04 }}"), 
        eta_w3_lower_limits => (X"{{ o1.etaW3LowerLimit|X04 }}", X"{{ o2.etaW3LowerLimit|X04 }}", X"{{ o3.etaW3LowerLimit|X04 }}", X"{{ o4.etaW3LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 4 or o2.etaNrCuts >= 4 or o3.etaNrCuts >= 4 or o4.etaNrCuts >= 4 %}
        eta_w4_upper_limits => (X"{{ o1.etaW4UpperLimit|X04 }}", X"{{ o2.etaW4UpperLimit|X04 }}", X"{{ o3.etaW4UpperLimit|X04 }}", X"{{ o4.etaW4UpperLimit|X04 }}"), 
        eta_w4_lower_limits => (X"{{ o1.etaW4LowerLimit|X04 }}", X"{{ o2.etaW4LowerLimit|X04 }}", X"{{ o3.etaW4LowerLimit|X04 }}", X"{{ o4.etaW4LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 5 or o2.etaNrCuts >= 5 or o3.etaNrCuts >= 5 or o4.etaNrCuts >= 5 %}
        eta_w5_upper_limits => (X"{{ o1.etaW5UpperLimit|X04 }}", X"{{ o2.etaW5UpperLimit|X04 }}", X"{{ o3.etaW5UpperLimit|X04 }}", X"{{ o4.etaW5UpperLimit|X04 }}"), 
        eta_w5_lower_limits => (X"{{ o1.etaW5LowerLimit|X04 }}", X"{{ o2.etaW5LowerLimit|X04 }}", X"{{ o3.etaW5LowerLimit|X04 }}", X"{{ o4.etaW5LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.phiFullRange == 'true' and o2.phiFullRange == 'true' and o3.phiFullRange == 'true' and o4.phiFullRange == 'true'  %}
        -- no phi cuts    
    {%- else %}
        phi_full_range => ({{ o1.phiFullRange }}, {{ o2.phiFullRange }}, {{ o3.phiFullRange }}, {{ o4.phiFullRange }}), 
        phi_w1_upper_limits => (X"{{ o1.phiW1UpperLimit|X04 }}", X"{{ o2.phiW1UpperLimit|X04 }}", X"{{ o3.phiW1UpperLimit|X04 }}", X"{{ o4.phiW1UpperLimit|X04 }}"), 
        phi_w1_lower_limits => (X"{{ o1.phiW1LowerLimit|X04 }}", X"{{ o2.phiW1LowerLimit|X04 }}", X"{{ o3.phiW1LowerLimit|X04 }}", X"{{ o4.phiW1LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.phiW2Ignore == 'false' and o2.phiW2Ignore == 'false' and o3.phiW2Ignore == 'false' and o4.phiW2Ignore == 'false'  %}
        phi_w2_ignore => ({{ o1.phiW2Ignore }}, {{ o2.phiW2Ignore }}, {{ o3.phiW2Ignore }}, {{ o4.phiW2Ignore }}), 
        phi_w2_upper_limits => (X"{{ o1.phiW2UpperLimit|X04 }}", X"{{ o2.phiW2UpperLimit|X04 }}", X"{{ o3.phiW2UpperLimit|X04 }}", X"{{ o4.phiW2UpperLimit|X04 }}"), 
        phi_w2_lower_limits => (X"{{ o1.phiW2LowerLimit|X04 }}", X"{{ o2.phiW2LowerLimit|X04 }}", X"{{ o3.phiW2LowerLimit|X04 }}", X"{{ o4.phiW2LowerLimit|X04 }}"),
    {%- endif %}    
    {%- if o1.isolationLUT != 15 or o2.isolationLUT != 15 or o3.isolationLUT != 15 or o4.isolationLUT != 15 %}
        iso_luts => (X"{{ o1.isolationLUT|X01 }}", X"{{ o2.isolationLUT|X01 }}", X"{{ o3.isolationLUT|X01 }}", X"{{ o4.isolationLUT|X01 }}"),
    {%- else %}
        -- no isolation cuts
    {%- endif %}    
-- correlation cuts
    {%- if condition.twoBodyPt.enabled == "true" %}
        twobody_pt_cut => true,        
        tbpt_threshold => X"{{ condition.twoBodyPt.threshold|X16 }}"
    {%- else %}
        twobody_pt_cut => false        
    {%- endif %}
    )
    port map(lhc_clk, {{ o1.type|lower }}_bx_{{ o1.bx }},
    {%- if condition.twoBodyPt.enabled == "true" %}
        tbpt => {{ o1.type|lower }}_{{ o2.type|lower }}_bx_{{ o1.bx }}_bx_{{ o2.bx }}_tbpt_vector,
    {%- endif %}
        condition_o => {{ condition.vhdl_signal }});
{%- endblock instantiate_calo_condition %}
