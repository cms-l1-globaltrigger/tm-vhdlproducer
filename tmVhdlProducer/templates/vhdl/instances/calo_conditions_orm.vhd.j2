{%- block instantiate_calo_conditions_orm %}
  {%- set o1 = condition.objects[0] %}
  {%- set o2 = condition.objects[1] %}
  {%- set o3 = condition.objects[2] %}
  {%- set o4 = condition.objects[3] %}
  {%- set nr_requirements = condition.nr_objects-1 %}
    {%- if nr_requirements == 4 %}
    {%- set orm_o = condition.objects[4] %}
    {%- elif nr_requirements == 3 %}
    {%- set orm_o = condition.objects[3] %}
    {%- elif nr_requirements == 2 %}
    {%- set orm_o = condition.objects[2] %}
    {%- elif nr_requirements == 1 %}
    {%- set orm_o = condition.objects[1] %}
    {%- endif %}
{{ condition.vhdl_signal }}_i: entity work.calo_conditions_orm
    generic map(
-- parameter for object 1
        obj_type_calo1 => {{ o1.type|upper }}_TYPE,
        nr_obj_calo1 => NR_{{ o1.type|upper }}_OBJECTS,
        calo1_object_slice_1_low => {{ o1.sliceLow }}, calo1_object_slice_1_high => {{ o1.sliceHigh }}, 
    {%- if nr_requirements >= 2 %}
        calo1_object_slice_2_low => {{ o2.sliceLow }}, calo1_object_slice_2_high => {{ o2.sliceHigh }}, 
    {%- endif %}    
    {%- if nr_requirements >= 3 %}
        calo1_object_slice_3_low => {{ o3.sliceLow }}, calo1_object_slice_3_high => {{ o3.sliceHigh }}, 
    {%- endif %}    
    {%- if nr_requirements >= 4 %}
        calo1_object_slice_4_low => {{ o4.sliceLow }}, calo1_object_slice_4_high => {{ o4.sliceHigh }}, 
    {%- endif %}    
        nr_templates => {{ nr_requirements }},
    {%- if o1.operator == 'false'  %}
        pt_ge_mode_calo1 => ({{ o1.operator }}, {{ o2.operator }}, {{ o3.operator }}, {{ o4.operator }}),
    {%- endif %}
        pt_thresholds_calo1 => (X"{{ o1.threshold|X04 }}", X"{{ o2.threshold|X04 }}", X"{{ o3.threshold|X04 }}", X"{{ o4.threshold|X04 }}"),
    {%- if o1.etaNrCuts == 0 and o2.etaNrCuts == 0 and o3.etaNrCuts == 0 and o4.etaNrCuts == 0 %}
        -- no eta cuts
    {%- endif %}
    {%- if o1.etaNrCuts >= 1 or o2.etaNrCuts >= 1 or o3.etaNrCuts >= 1 or o4.etaNrCuts >= 1 %}
        nr_eta_windows => ({{ o1.etaNrCuts }}, {{ o2.etaNrCuts }}, {{ o3.etaNrCuts }}, {{ o4.etaNrCuts }}),
        eta_w1_upper_limits_calo1 => (X"{{ o1.etaW1UpperLimit|X04 }}", X"{{ o2.etaW1UpperLimit|X04 }}", X"{{ o3.etaW1UpperLimit|X04 }}", X"{{ o4.etaW1UpperLimit|X04 }}"), 
        eta_w1_lower_limits_calo1 => (X"{{ o1.etaW1LowerLimit|X04 }}", X"{{ o2.etaW1LowerLimit|X04 }}", X"{{ o3.etaW1LowerLimit|X04 }}", X"{{ o4.etaW1LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 2 or o2.etaNrCuts >= 2 or o3.etaNrCuts >= 2 or o4.etaNrCuts >= 2 %}
        eta_w2_upper_limits_calo1 => (X"{{ o1.etaW2UpperLimit|X04 }}", X"{{ o2.etaW2UpperLimit|X04 }}", X"{{ o3.etaW2UpperLimit|X04 }}", X"{{ o4.etaW2UpperLimit|X04 }}"), 
        eta_w2_lower_limits_calo1 => (X"{{ o1.etaW2LowerLimit|X04 }}", X"{{ o2.etaW2LowerLimit|X04 }}", X"{{ o3.etaW2LowerLimit|X04 }}", X"{{ o4.etaW2LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 3 or o2.etaNrCuts >= 3 or o3.etaNrCuts >= 3 or o4.etaNrCuts >= 3 %}
        eta_w3_upper_limits_calo1 => (X"{{ o1.etaW3UpperLimit|X04 }}", X"{{ o2.etaW3UpperLimit|X04 }}", X"{{ o3.etaW3UpperLimit|X04 }}", X"{{ o4.etaW3UpperLimit|X04 }}"), 
        eta_w3_lower_limits_calo1 => (X"{{ o1.etaW3LowerLimit|X04 }}", X"{{ o2.etaW3LowerLimit|X04 }}", X"{{ o3.etaW3LowerLimit|X04 }}", X"{{ o4.etaW3LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 4 or o2.etaNrCuts >= 4 or o3.etaNrCuts >= 4 or o4.etaNrCuts >= 4 %}
        eta_w4_upper_limits_calo1 => (X"{{ o1.etaW4UpperLimit|X04 }}", X"{{ o2.etaW4UpperLimit|X04 }}", X"{{ o3.etaW4UpperLimit|X04 }}", X"{{ o4.etaW4UpperLimit|X04 }}"), 
        eta_w4_lower_limits_calo1 => (X"{{ o1.etaW4LowerLimit|X04 }}", X"{{ o2.etaW4LowerLimit|X04 }}", X"{{ o3.etaW4LowerLimit|X04 }}", X"{{ o4.etaW4LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.etaNrCuts >= 5 or o2.etaNrCuts >= 5 or o3.etaNrCuts >= 5 or o4.etaNrCuts >= 5 %}
        eta_w5_upper_limits_calo1 => (X"{{ o1.etaW5UpperLimit|X04 }}", X"{{ o2.etaW5UpperLimit|X04 }}", X"{{ o3.etaW5UpperLimit|X04 }}", X"{{ o4.etaW5UpperLimit|X04 }}"), 
        eta_w5_lower_limits_calo1 => (X"{{ o1.etaW5LowerLimit|X04 }}", X"{{ o2.etaW5LowerLimit|X04 }}", X"{{ o3.etaW5LowerLimit|X04 }}", X"{{ o4.etaW5LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.phiFullRange == 'true' and o2.phiFullRange == 'true' and o3.phiFullRange == 'true' and o4.phiFullRange == 'true'  %}
        -- no phi cuts    
    {%- else %}
        phi_full_range_calo1 => ({{ o1.phiFullRange }}, {{ o2.phiFullRange }}, {{ o3.phiFullRange }}, {{ o4.phiFullRange }}), 
        phi_w1_upper_limits_calo1 => (X"{{ o1.phiW1UpperLimit|X04 }}", X"{{ o2.phiW1UpperLimit|X04 }}", X"{{ o3.phiW1UpperLimit|X04 }}", X"{{ o4.phiW1UpperLimit|X04 }}"), 
        phi_w1_lower_limits_calo1 => (X"{{ o1.phiW1LowerLimit|X04 }}", X"{{ o2.phiW1LowerLimit|X04 }}", X"{{ o3.phiW1LowerLimit|X04 }}", X"{{ o4.phiW1LowerLimit|X04 }}"),
    {%- endif %}
    {%- if o1.phiW2Ignore == 'false' and o2.phiW2Ignore == 'false' and o3.phiW2Ignore == 'false' and o4.phiW2Ignore == 'false'  %}
        phi_w2_ignore_calo1 => ({{ o1.phiW2Ignore }}, {{ o2.phiW2Ignore }}, {{ o3.phiW2Ignore }}, {{ o4.phiW2Ignore }}), 
        phi_w2_upper_limits_calo1 => (X"{{ o1.phiW2UpperLimit|X04 }}", X"{{ o2.phiW2UpperLimit|X04 }}", X"{{ o3.phiW2UpperLimit|X04 }}", X"{{ o4.phiW2UpperLimit|X04 }}"), 
        phi_w2_lower_limits_calo1 => (X"{{ o1.phiW2LowerLimit|X04 }}", X"{{ o2.phiW2LowerLimit|X04 }}", X"{{ o3.phiW2LowerLimit|X04 }}", X"{{ o4.phiW2LowerLimit|X04 }}"),
    {%- endif %}    
    {%- if o1.isolationLUT != 15 or o2.isolationLUT != 15 or o3.isolationLUT != 15 or o4.isolationLUT != 15 %}
        iso_luts_calo1 => (X"{{ o1.isolationLUT|X01 }}", X"{{ o2.isolationLUT|X01 }}", X"{{ o3.isolationLUT|X01 }}", X"{{ o4.isolationLUT|X01 }}"),
    {%- else %}
        -- no isolation cuts
    {%- endif %}    
-- parameter for overlap removel object
        obj_type_calo2 => {{ orm_o.type|upper }}_TYPE,
        nr_obj_calo2 => NR_{{ orm_o.type|upper }}_OBJECTS,
        calo2_object_slice_1_low => {{ orm_o.sliceLow }},
        calo2_object_slice_1_high => {{ orm_o.sliceHigh }}, 
    {%- if o1.operator == 'false'  %}
        pt_ge_mode_calo2 => {{ orm_o.operator }},
    {%- endif %}
        pt_thresholds_calo2 => X"{{ orm_o.threshold|X04 }}"
    {%- if orm_o.etaNrCuts == 0  %}
        -- no eta cuts
    {%- endif %}
    {%- if orm_o.etaNrCuts >= 1 %}
        nr_eta_windows_calorm_o => {{ orm_o.etaNrCuts }},
        eta_w1_upper_limits_calo2 => X"{{ orm_o.etaW1UpperLimit|X04 }}", 
        eta_w1_lower_limits_calo2 => X"{{ orm_o.etaW1LowerLimit|X04 }}",
    {%- endif %}
    {%- if orm_o.etaNrCuts >= 2 %}
        eta_w2_upper_limits_calo2 => X"{{ orm_o.etaW2UpperLimit|X04 }}"
        eta_w2_lower_limits_calo2 => X"{{ orm_o.etaW2LowerLimit|X04 }}"
    {%- endif %}
    {%- if orm_o.etaNrCuts >= 3 %}
        eta_w3_upper_limits_calo2 => X"{{ orm_o.etaW3UpperLimit|X04 }}" 
        eta_w3_lower_limits_calo2 => X"{{ orm_o.etaW3LowerLimit|X04 }}"
    {%- endif %}
    {%- if orm_o.etaNrCuts >= 4 %}
        eta_w4_upper_limits_calo2 => X"{{ orm_o.etaW4UpperLimit|X04 }}", 
        eta_w4_lower_limits_calo2 => X"{{ orm_o.etaW4LowerLimit|X04 }}",
    {%- endif %}
    {%- if orm_o.etaNrCuts >= 5 %}
        eta_w5_upper_limits_calo2 => X"{{ orm_o.etaW5UpperLimit|X04 }}",
        eta_w5_lower_limits_calo2 => X"{{ orm_o.etaW5LowerLimit|X04 }}",
    {%- endif %}
    {%- if orm_o.phiFullRange == 'true' %}
        -- no phi cuts    
    {%- else %}
        phi_full_range_calo2 => {{ orm_o.phiFullRange }}, 
        phi_w1_upper_limits_calo2 => X"{{ orm_o.phiW1UpperLimit|X04 }}", 
        phi_w1_lower_limits_calo2 => X"{{ orm_o.phiW1LowerLimit|X04 }}",
    {%- endif %}
    {%- if orm_o.phiW2Ignore == 'false' %}
        phi_w2_ignore_calo2 => {{ orm_o.phiW2Ignore }},
        phi_w2_upper_limits_calo2 => X"{{ orm_o.phiW2UpperLimit|X04 }}", 
        phi_w2_lower_limits_calo2 => X"{{ orm_o.phiW2LowerLimit|X04 }}",
    {%- endif %}    
    {%- if orm_o.isolationLUT != 15 %}
        iso_luts_calo2 => X"{{ orm_o.isolationLUT|X01 }}",
    {%- else %}
        -- no isolation cuts
    {%- endif %}    
-- correlation cuts for overlap removal
    {%- if condition.deltaEtaOrm.enabled == 'true'  %}
        deta_orm_cut => {{ condition.deltaEtaOrm.enabled }},
        deta_orm_upper_limit => X"{{ condition.deltaEtaOrm.upper|X08 }}", 
        deta_orm_lower_limit => X"{{ condition.deltaEtaOrm.lower|X08 }}",
    {%- endif %}
    {%- if condition.deltaPhiOrm.enabled == 'true'  %}
        dphi_orm_cut => {{ condition.deltaPhiOrm.enabled }},
        dphi_orm_upper_limit => X"{{ condition.deltaPhiOrm.upper|X08 }}", 
        dphi_orm_lower_limit => X"{{ condition.deltaPhiOrm.lower|X08 }}",
    {%- endif %}
    {%- if condition.deltaROrm.enabled == 'true'  %}
        dr_orm_cut => {{ condition.deltaROrm.enabled }},
        dr_orm_upper_limit => X"{{ condition.deltaROrm.upper|X16 }}", 
        dr_orm_lower_limit => X"{{ condition.deltaROrm.lower|X16 }}",
    {%- endif %}
    {%- if condition.twoBodyPt.enabled == "true" %}
        twobody_pt_cut => true,        
        tbpt_threshold => X"{{ condition.twoBodyPt.threshold|X16 }}"
    {%- else %}
        twobody_pt_cut => false        
    {%- endif %}
    )
    port map(lhc_clk, {{ o1.type|lower }}_bx_{{ o1.bx }},
    {%- if condition.deltaEtaOrm.enabled == 'true' %}
        deta_orm => {{ o1.type|lower }}_{{ orm_o.type|lower }}_bx_{{ o1.bx }}_bx_{{ orm_o.bx }}_deta_vector,
    {%- endif %}
    {%- if condition.deltaPhiOrm.enabled == 'true' %}
        dphi_orm => {{ o1.type|lower }}_{{ orm_o.type|lower }}_bx_{{ o1.bx }}_bx_{{ orm_o.bx }}_dphi_vector,
    {%- endif %}
    {%- if condition.deltaROrm.enabled == 'true' %}
        dr_orm => {{ o1.type|lower }}_{{ orm_o.type|lower }}_bx_{{ o1.bx }}_bx_{{ orm_o.bx }}_delta_r_vector,
    {%- endif %}
    {%- if condition.twoBodyPt.enabled == "true" %}
        tbpt => {{ o1.type|lower }}_{{ o1.type|lower }}_bx_{{ o1.bx }}_bx_{{ o1.bx }}_tbpt_vector,
    {%- endif %}
        condition_o => {{ condition.vhdl_signal }});
{%- endblock instantiate_calo_conditions_orm %}
{# eof #}
